        "genericAuthType": "httpBearerAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "fields", "value": "id" },
            { "name": "limit", "value": "-1" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "fetch_valid_objects",
      "name": "Fetch Valid Objects",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [880, 0],
      "credentials": {
        "httpBearerAuth": { "id": "DIRECTUS_CREDENTIAL_ID", "name": "Directus Admin Token" }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://directus:8055/items/labbis_pick_list_value",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "fields", "value": "GuidId,Title" },
            { "name": "limit", "value": "-1" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "fetch_pick_list",
      "name": "Fetch PickList Values",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1100, 0],
      "credentials": {
        "httpBearerAuth": { "id": "DIRECTUS_CREDENTIAL_ID", "name": "Directus Admin Token" }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://directus:8055/items/labbis_defect_act",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "fields", "value": "DefectActId,ActNumber,DefectActDate,ObjectId,Problem,Place,Status,Description,Solution,SystemosId,SystGroupId" },
            { "name": "limit", "value": "-1" }
          ]
        },
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "fetch_mirror",
      "name": "Fetch from Mirror",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, 0],
      "credentials": {
        "httpBearerAuth": { "id": "DIRECTUS_CREDENTIAL_ID", "name": "Directus Admin Token" }
      }
    },
    {
      "parameters": {
        "jsCode": "const pickListResponse = $('Fetch PickList Values').first().json;\nconst pickListItems = pickListResponse.data || [];\nconst statusMap = new Map();\nfor (const plv of pickListItems) {\n  if (plv.GuidId && plv.Title) {\n    statusMap.set(plv.GuidId, plv.Title);\n  }\n}\n\nconst existingResponse = $('Fetch Existing DefectActs').first().json;\nconst existingIds = new Set((existingResponse.data || []).map(d => d.labbis_id));\n\nconst validSystems = new Set(($('Fetch Valid Systems').first().json.data || []).map(d => d.id));\nconst validGroups = new Set(($('Fetch Valid SystGroups').first().json.data || []).map(d => d.id));\nconst validObjects = new Set(($('Fetch Valid Objects').first().json.data || []).map(d => d.id));\n\nconst mirrorResponse = $input.first().json;\nconst mirrorItems = mirrorResponse.data || [];\nconst results = [];\n\nfor (const da of mirrorItems) {\n  if (!da.DefectActId) continue;\n  if (existingIds.has(da.DefectActId)) continue;\n\n  results.push({\n    json: {\n      id: da.DefectActId,\n      act_number: da.ActNumber || null,\n      defect_date: da.DefectActDate || null,\n      object_id: (da.ObjectId && validObjects.has(da.ObjectId)) ? da.ObjectId : null,\n      problem: da.Problem || null,\n      place: da.Place || null,\n      status: statusMap.get(da.Status) || da.Status || 'Unknown',\n      description: da.Description || null,\n      solution: da.Solution || null,\n      system_id: (da.SystemosId && validSystems.has(da.SystemosId)) ? da.SystemosId : null,\n      system_group_id: (da.SystGroupId && validGroups.has(da.SystGroupId)) ? da.SystGroupId : null,\n      labbis_id: da.DefectActId\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "map_fields",
      "name": "Map + Status + Dedup + FK Validate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://directus:8055/items/defect_acts",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "response": { "response": { "responseFormat": "json" } }
        }
      },
      "id": "upsert_directus",
      "name": "Insert to Dashboard",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1760, 0],
      "credentials": {
        "httpBearerAuth": { "id": "DIRECTUS_CREDENTIAL_ID", "name": "Directus Admin Token" }
      },
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet created = 0;\nlet skipped = 0;\nlet errors = 0;\n\nfor (const item of items) {\n  const status = item.json?.statusCode;\n  if (status === 200 || status === 204 || item.json?.data?.id) {\n    created++;\n  } else if (status === 400 && JSON.stringify(item.json).includes('unique')) {\n    skipped++;\n  } else {\n    errors++;\n  }\n}\n\nreturn [{\n  json: {\n    total_processed: items.length,\n    created,\n    skipped,\n    errors,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "summary",
      "name": "Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1980, 0]
    }
  ],
  "connections": {
    "Manual Trigger": {
      "main": [[{ "node": "Fetch Existing DefectActs", "type": "main", "index": 0 }]]
    },
    "Fetch Existing DefectActs": {
      "main": [[{ "node": "Fetch Valid Systems", "type": "main", "index": 0 }]]
    },
    "Fetch Valid Systems": {
      "main": [[{ "node": "Fetch Valid SystGroups", "type": "main", "index": 0 }]]
    },
    "Fetch Valid SystGroups": {
      "main": [[{ "node": "Fetch Valid Objects", "type": "main", "index": 0 }]]
    },
    "Fetch Valid Objects": {
      "main": [[{ "node": "Fetch PickList Values", "type": "main", "index": 0 }]]
    },
    "Fetch PickList Values": {
      "main": [[{ "node": "Fetch from Mirror", "type": "main", "index": 0 }]]
    },
    "Fetch from Mirror": {
      "main": [[{ "node": "Map + Status + Dedup + FK Validate", "type": "main", "index": 0 }]]
    },
    "Map + Status + Dedup + FK Validate": {
      "main": [[{ "node": "Insert to Dashboard", "type": "main", "index": 0 }]]
    },
    "Insert to Dashboard": {
      "main": [[{ "node": "Summary", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
